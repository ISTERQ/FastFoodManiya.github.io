{
  "version": 2,
  "routes": [
    { "src": "/img/(.*)", "dest": "/img/$1" },
    { "src": "/style.css", "dest": "/style.css" },
    { "src": "/script.js", "dest": "/script.js" },
    { "src": "/register", "dest": "/server.js" },
    { "src": "/login", "dest": "/server.js" },
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
